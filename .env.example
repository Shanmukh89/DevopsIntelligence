# --- Core URLs (Docker defaults match docker-compose service names) ---
DATABASE_URL=postgresql://auditr:changeme@postgres:5432/auditr
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL (used by docker-compose for postgres service) ---
POSTGRES_USER=auditr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=auditr

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=auditr
CLICKHOUSE_URL=http://default@clickhouse:8123/auditr

# --- GitHub App / webhooks ---
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/github/callback
AUDITR_DOMAIN=http://127.0.0.1:8000
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000
FERNET_KEY=

# --- AI providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL=

# --- App / CORS ---
CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost/api
SECRET_KEY=change-me-in-production

# --- Celery (optional overrides) ---
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
